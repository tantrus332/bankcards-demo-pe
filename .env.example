# Параметры для подключения к БД
POSTGRES_DB=bankdb
POSTGRES_USER=bank_user
POSTGRES_PASSWORD=bank_pass
DB_PORT=5432

# Пример JWT secret
APP_JWT_SECRET="your_secure_jwt_secret_token_here_12345"

# Длительность действия JWT
APP_JWT_EXPIRATION=3600000

# Пример ключа шифрования номеров карт
APP_ENCRYPTION_KEY="1234567890123456"

SPRING_PROFILES_ACTIVE=dev
